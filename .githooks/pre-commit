#!/bin/sh

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED_KOTLIN_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(kt|kts)$' || true)"

if [ -z "$STAGED_KOTLIN_FILES" ]; then
    exit 0
fi

echo "Running detekt for staged Kotlin changes..."
./gradlew detektAll
